# Discord Channel Server 环境变量配置

# ===========================================
# Craft Agent 服务器配置 (必需)
# ===========================================

# WebSocket RPC 服务器地址
CRAFT_SERVER_URL=ws://127.0.0.1:9100

# 服务器认证令牌
CRAFT_SERVER_TOKEN=your-server-token

# 默认工作区 ID
DEFAULT_WORKSPACE_ID=your-workspace-id

# ===========================================
# Discord 配置 (必需)
# ===========================================

# Discord Bot Token (从 Discord Developer Portal 获取)
DISCORD_BOT_TOKEN=your-discord-bot-token

# ===========================================
# 可选配置
# ===========================================

# 允许的频道 ID (逗号分隔，留空则允许所有)
DISCORD_CHANNEL_IDS=

# 允许的用户 ID (逗号分隔，留空则允许所有)
DISCORD_USER_IDS=

# 允许的服务器 ID (逗号分隔，留空则允许所有)
DISCORD_GUILD_IDS=

# 默认权限模式: safe | ask | allow-all
DEFAULT_PERMISSION_MODE=ask

# 会话空闲超时时间 (毫秒)，默认 30 分钟
IDLE_CLEANUP_TIME=1800000
