# Feishu Channel Server 环境变量配置

# ===========================================
# Craft Agent 服务器配置 (必需)
# ===========================================

# WebSocket RPC 服务器地址
CRAFT_SERVER_URL=ws://127.0.0.1:9100

# 服务器认证令牌
CRAFT_SERVER_TOKEN=your-server-token

# 默认工作区 ID
DEFAULT_WORKSPACE_ID=your-workspace-id

# ===========================================
# 飞书配置 (必需)
# ===========================================

# 飞书应用 ID (从飞书开放平台获取)
FEISHU_APP_ID=cli_xxxxxxxxxxxx

# 飞书应用密钥
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 可选配置
# ===========================================

# 域名: feishu (国内) 或 lark (国际)
FEISHU_DOMAIN=feishu

# 加密密钥 (如果配置了事件订阅加密)
FEISHU_ENCRYPT_KEY=

# 验证令牌 (如果配置了事件订阅验证)
FEISHU_VERIFICATION_TOKEN=

# 消息渲染模式: text (纯文本) 或 card (卡片)
FEISHU_RENDER_MODE=text

# 允许的聊天 ID (逗号分隔，留空则允许所有)
FEISHU_CHAT_IDS=

# 允许的用户 ID (逗号分隔，留空则允许所有)
FEISHU_USER_IDS=

# 默认权限模式: safe | ask | allow-all
DEFAULT_PERMISSION_MODE=ask

# 会话空闲超时时间 (毫秒)，默认 30 分钟
IDLE_CLEANUP_TIME=1800000

# 启用调试日志
DEBUG=false
